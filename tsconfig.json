{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["playwright-tests/pages/*"]
    }
  },
  "include": ["playwright-tests/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
